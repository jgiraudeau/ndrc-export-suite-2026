generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  name               String
  status             String              @default("pending")
  consentGivenAt     DateTime?
  createdAt          DateTime            @default(now())
  classes            Class[]
  comments           Comment[]
  evaluationsGiven   Evaluation[]
  missionAssignments MissionAssignment[]
  savedDocuments     SavedDocument[]
  students           Student[]
}

model Class {
  id        String    @id @default(cuid())
  code      String
  name      String
  teacherId String
  createdAt DateTime  @default(now())
  teacher   Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students  Student[]

  @@unique([code, teacherId])
}

model Student {
  id                  String                   @id @default(cuid())
  firstName           String
  lastName            String
  identifier          String                   @unique
  passwordHash        String
  wpUrl               String?
  prestaUrl           String?
  teacherId           String
  classId             String
  consentGivenAt      DateTime?
  createdAt           DateTime                 @default(now())
  comments            Comment[]
  evaluationsOfficial Evaluation[]
  missions            MissionAssignment[]
  experiences         ProfessionalExperience[]
  progress            Progress[]
  chatSessions        ChatSession[]
  class               Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher             Teacher                  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, firstName, lastName])
}

model Progress {
  id              String    @id @default(cuid())
  studentId       String
  competencyId    String
  acquired        Boolean   @default(false)
  status          Int       @default(0)
  proof           String?
  updatedAt       DateTime  @updatedAt
  teacherStatus   Int?
  teacherFeedback String?
  teacherGradedAt DateTime?
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, competencyId])
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  teacherId String
  studentId String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Mission {
  id            String              @id @default(cuid())
  title         String
  content       String
  platform      String
  level         Int                 @default(2)
  competencyIds String[]
  createdBy     String
  createdByRole String
  createdAt     DateTime            @default(now())
  assignments   MissionAssignment[]
}

model MissionAssignment {
  id          String         @id @default(cuid())
  missionId   String
  studentId   String
  teacherId   String
  status      String         @default("pending")
  assignedAt  DateTime       @default(now())
  completedAt DateTime?
  journal     JournalEntry[]
  mission     Mission        @relation(fields: [missionId], references: [id], onDelete: Cascade)
  student     Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher     Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([missionId, studentId])
}

model Competency {
  id          String                @id @default(cuid())
  code        String                @unique
  description String
  block       String
  createdAt   DateTime              @default(now())
  criteria    AssessmentCriterion[]
}

model AssessmentCriterion {
  id           String            @id @default(cuid())
  competencyId String
  description  String
  weight       Float             @default(1.0)
  competency   Competency        @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  scores       EvaluationScore[]
}

model EvaluationSession {
  id          String       @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  evaluations Evaluation[]
}

model Evaluation {
  id            String             @id @default(cuid())
  studentId     String
  evaluatorId   String
  sessionId     String?
  date          DateTime
  type          String             @default("formative")
  situation     String
  globalComment String?
  createdAt     DateTime           @default(now())
  evaluator     Teacher            @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  session       EvaluationSession? @relation(fields: [sessionId], references: [id])
  student       Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scores        EvaluationScore[]
}

model EvaluationScore {
  id           String              @id @default(cuid())
  evaluationId String
  criterionId  String
  score        Float
  comment      String?
  criterion    AssessmentCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  evaluation   Evaluation          @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
}

model SavedDocument {
  id           String   @id @default(cuid())
  title        String
  content      String
  documentType String
  teacherId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model ProfessionalExperience {
  id            String         @id @default(cuid())
  title         String
  type          String
  description   String
  startDate     DateTime
  endDate       DateTime?
  studentId     String
  competencyIds String[]
  status        String         @default("DRAFT")
  feedback      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  journal       JournalEntry[]
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id             String                  @id @default(cuid())
  date           DateTime                @default(now())
  content        String
  proofs         String[]
  links          String[]
  teacherComment String?
  isValidated    Boolean                 @default(false)
  experienceId   String?
  assignmentId   String?
  createdAt      DateTime                @default(now())
  assignment     MissionAssignment?      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  experience     ProfessionalExperience? @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String
  studentId String
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
