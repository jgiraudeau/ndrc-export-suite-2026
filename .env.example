# =============================================================
# integration — Variables d'environnement
# Copier ce fichier en .env pour le développement local
# Configurer ces variables dans Vercel pour la production
# =============================================================

# -------------------------------------------------------------
# BASE DE DONNEES (Railway PostgreSQL)
# -------------------------------------------------------------
DATABASE_PUBLIC_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# -------------------------------------------------------------
# AUTHENTIFICATION
# -------------------------------------------------------------
JWT_SECRET=remplacer-par-une-valeur-longue-et-aleatoire
ADMIN_EMAIL=admin@integration.app
ADMIN_PASSWORD=mot-de-passe-admin-fort

# -------------------------------------------------------------
# APPLICATION
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHM_MANAGER_URL=https://whm-manager.vercel.app

# -------------------------------------------------------------
# STOCKAGE
# -------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# -------------------------------------------------------------
# IA — GOOGLE GEMINI (projet dedie integration)
# -------------------------------------------------------------
# Recommandation:
# - 1 projet GCP par application
# - 1 cle API dediee par application
#
# Le code accepte GEMINI_API_KEY ou GOOGLE_API_KEY.
# Pour simplifier, preferer GEMINI_API_KEY.
GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...

# -------------------------------------------------------------
# RAG / FILE SEARCH (optionnel)
# -------------------------------------------------------------
RAG_GLOBAL_STORE_NAME=integration-rag-global-knowledge
# RAG_KNOWLEDGE_DIR=/chemin/vers/knowledge
